# Database
DB_URL=
LOCAL_DB=true  # remove this in production (Vercel), only applicable for local postgres db

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Cloudflare R2 (S3-compatible) - private bucket for member photos, documents
# and the family gallery. Files are served via short-lived presigned URLs.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (email) — swap _provider.ts to use a different provider
# RESEND_FROM must be a verified sender domain in Resend.
# Defaults to onboarding@resend.dev in dev (Resend test address).
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.com
